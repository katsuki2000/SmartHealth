generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["windows", "native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  role         String        @default("DOCTOR")
  createdAt    DateTime      @default(now())
  practitioner Practitioner?
}

model Patient {
  id             String         @id @default(uuid())
  firstName      String
  lastName       String
  birthDate      DateTime
  gender         String
  
  // Médecin traitant / Créateur (Optionnel pour supporter FHIR)
  practitionerId String?
  practitioner   Practitioner?  @relation(fields: [practitionerId], references: [id])

  appointments   Appointment[]
  prescriptions  Prescription[]
  accessLogs     AccessLog[]
  createdAt      DateTime       @default(now())
}

model Practitioner {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  specialty     String
  email         String?        @unique
  phone         String?
  
  // Lien vers le compte de connexion
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id])

  patients      Patient[]
  appointments  Appointment[]
  prescriptions Prescription[]
  accessLogs    AccessLog[]
  createdAt     DateTime       @default(now())
}

model Appointment {
  id             String         @id @default(uuid())
  dateTime       DateTime
  status         String         @default("SCHEDULED")
  reason         String?
  patientId      String
  practitionerId String
  patient        Patient        @relation(fields: [patientId], references: [id])
  practitioner   Practitioner   @relation(fields: [practitionerId], references: [id])
  prescriptions  Prescription[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Prescription {
  id             String       @id @default(uuid())
  medications    String       
  instructions   String?
  issuedAt       DateTime     @default(now())
  
  appointmentId  String?      
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
}

// ─── Break-The-Glass Audit Logging ────────────────────────
model AccessLog {
  id             String       @id @default(uuid())
  practitionerId String
  patientId      String
  reason         String
  accessedAt     DateTime     @default(now())

  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  patient        Patient      @relation(fields: [patientId], references: [id])
}

// ─── FHIR Native Storage ─────────────────────────────
// Stores raw FHIR R4 resources (Synthea-compatible) as JSONB.
// resourceType: "Patient", "Observation", "Encounter", etc.
model FhirResource {
  id           String   @id @default(uuid())
  resourceType String
  content      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([resourceType])
  @@map("fhir_resources")
}
