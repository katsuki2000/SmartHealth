generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["windows", "native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  birthDate DateTime
  gender    String
  createdAt DateTime @default(now())
}
